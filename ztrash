VERSION="1.0.0"

# --- Configuration & Setup ---
setopt EXTENDED_GLOB NO_UNSET

TRASH_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/Trash"
FILES_DIR="$TRASH_DIR/files"
INFO_DIR="$TRASH_DIR/info"

mkdir -p "$FILES_DIR" "$INFO_DIR"

if [[ -t 1 ]]; then
    BOLD=$'\e[1m' DIM=$'\e[2m' RED=$'\e[31m' GREEN=$'\e[32m'
    YELLOW=$'\e[33m' BLUE=$'\e[34m' MAGENTA=$'\e[35m' CYAN=$'\e[36m' RESET=$'\e[0m'
else
    BOLD="" DIM="" RED="" GREEN="" YELLOW="" BLUE="" MAGENTA="" CYAN="" RESET=""
fi

# --- Helpers ---

url_decode() {
    if command -v python3 >/dev/null 2>&1; then
        python3 -c "import urllib.parse, sys; print(urllib.parse.unquote(sys.argv[1]), end='')" "$1"
    else
        local str="$1" decoded=""
        while [[ -n "$str" ]]; do
            if [[ "$str" = '%'([0-9a-fA-F][0-9a-fA-F])* ]]; then
                decoded+="\\x${match[1]}"
                str="${str#%??}"
            else
                decoded+="${str[1]}"
                str="${str:1}"
            fi
        done
        printf '%b' "$decoded"
    fi
}

url_encode() {
    if command -v python3 >/dev/null 2>&1; then
        python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]), end='')" "$1"
    else
        local str="$1" encoded="" c
        for (( i = 1; i <= ${#str}; i++ )); do
            c="$str[i]"
            case "$c" in
                [a-zA-Z0-9._~-]) encoded+="$c" ;;
                *) printf -v hex '%%%02X' "'$c"; encoded+="$hex" ;;
            esac
        done
        printf '%s' "$encoded"
    fi
}

get_size() {
    if [[ -e "$1" || -L "$1" ]]; then
        du -sh "$1" | cut -f1
    else
        echo "0B"
    fi
}

format_bytes() {
    local bytes=$1
    if (( bytes < 1024 )); then
        printf "%dB\n" "$bytes"
    elif (( bytes < 1048576 )); then
        printf "%.1fK\n" "$(( bytes / 1024. ))"
    elif (( bytes < 1073741824 )); then
        printf "%.1fM\n" "$(( bytes / 1048576. ))"
    else
        printf "%.1fG\n" "$(( bytes / 1073741824. ))"
    fi
}

truncate_path() {
    local path="$1" max=$2
    if [[ $max -le 0 ]]; then
        printf ''
    elif [[ $max -lt 4 ]]; then
        printf '%s' "${path:0:$max}"
    elif [[ ${#path} -gt $max ]]; then
        local half=$(( (max - 3) / 2 ))
        local half2=$(( max - 3 - half ))
        printf '%s' "${path:0:$half}...${path: -$half2}"
    else
        printf '%s' "$path"
    fi
}

date_to_epoch() {
    local date_str="$1"
    local epoch=$(date -d "$date_str" +%s 2>/dev/null)
    if [[ -z "$epoch" ]] && command -v python3 >/dev/null 2>&1; then
        epoch=$(python3 -c "
import sys
from datetime import datetime
try:
    dt = datetime.strptime(sys.argv[1], '%Y-%m-%dT%H:%M:%S')
    print(int(dt.timestamp()), end='')
except:
    pass
" "$date_str" 2>/dev/null)
    fi
    echo "$epoch"
}

purge_trash() {
    local days=$1
    local cutoff=$(date -d "$days days ago" +%s 2>/dev/null)
    if [[ -z "$cutoff" ]] && command -v python3 >/dev/null 2>&1; then
        cutoff=$(python3 -c "from datetime import datetime, timedelta; print(int((datetime.now() - timedelta(days=$days)).timestamp()), end='')" 2>/dev/null)
    fi
    if [[ -z "$cutoff" ]]; then
        echo "${RED}Error: Cannot compute cutoff date.${RESET}" >&2
        return 1
    fi

    local info_files=("$INFO_DIR"/*.trashinfo(N))
    local count=0 freed_bytes=0
    for f in $info_files; do
        local del_date=$(grep "^DeletionDate=" "$f" | cut -d= -f2)
        if [[ -n "$del_date" ]]; then
            local del_epoch=$(date_to_epoch "$del_date")
            if [[ -n "$del_epoch" && "$del_epoch" -lt "$cutoff" ]]; then
                local base=$(basename "$f" .trashinfo)
                local fbytes=$(du -sb "$FILES_DIR/$base" 2>/dev/null | cut -f1)
                freed_bytes=$(( freed_bytes + ${fbytes:-0} ))
                rm -rf "$FILES_DIR/$base" "$INFO_DIR/$base.trashinfo"
                ((count++))
            fi
        fi
    done
    local freed_fmt=$(format_bytes $freed_bytes)
    echo "${CYAN}Purged${RESET} ${RED}${BOLD}$count${RESET} item(s) (${YELLOW}$freed_fmt${RESET}) older than ${MAGENTA}$days${RESET} day(s)."
}

